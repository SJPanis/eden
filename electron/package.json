{
  "name": "eden",
  "version": "0.1.0",
  "description": "Eden — The AI Service Economy",
  "main": "main.js",
  "author": "SJPanis",
  "license": "MIT",
  "build": {
    "appId": "app.edencloud.eden",
    "productName": "Eden",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "SJPanis",
      "repo": "eden",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "boot.html",
        "to": "boot.html"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "boot.html"
    ]
  },
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
