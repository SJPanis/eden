# Eden — Local Development Environment
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.mommeuzwoadjyxvkzwrz.supabase.co:5432/postgres

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Stripe — use TEST keys locally (sk_test_ not sk_live_)
STRIPE_SECRET_KEY=sk_test_your_test_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://mommeuzwoadjyxvkzwrz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
EDEN_EARLY_ACCESS_ENABLED=true
