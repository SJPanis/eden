generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EdenRole {
  CONSUMER
  BUSINESS
  OWNER
}

enum UserStatus {
  ACTIVE
  REVIEW
  FROZEN
}

enum BusinessStatus {
  DRAFT
  TESTING
  PUBLISHED
}

enum BusinessVisibility {
  PRIVATE_PREVIEW
  INTERNAL_TESTING
  PUBLISHED
}

enum BusinessMemberRole {
  OWNER
  ADMIN
  EDITOR
  MEMBER
}

enum PipelineStatus {
  DRAFT
  TESTING
  READY
  PUBLISHED
}

enum CreditsTopUpPaymentStatus {
  PENDING
  SETTLED
  FAILED
  CANCELED
}

enum PaymentEventLogStatus {
  INFO
  SUCCESS
  SKIPPED
  FAILED
}

enum PayoutSettlementStatus {
  PENDING
  SETTLED
  CANCELED
}

enum ProjectBlueprintStatus {
  DRAFT
  TESTING
  PUBLISHED
  INACTIVE
}

enum ProjectRuntimeType {
  INTERNAL_SANDBOX
  INTERNAL_PREVIEW
  EDEN_MANAGED_INSTANCE
  EXTERNAL_LINKED_DOMAIN
}

enum ProjectRuntimeEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum ProjectRuntimeTarget {
  EDEN_INTERNAL
  EDEN_MANAGED
  EXTERNAL_DOMAIN
}

enum ProjectRuntimeAccessPolicy {
  OWNER_ONLY
  BUSINESS_MEMBERS
  PUBLIC
}

enum ProjectRuntimeVisibility {
  PRIVATE_INTERNAL
  PRIVATE_PREVIEW
  PUBLIC_LAUNCH
}

enum ProjectRuntimeStatus {
  REGISTERED
  CONFIGURING
  READY
  PAUSED
  ERROR
  ARCHIVED
}

enum ProjectRuntimeDomainLinkType {
  INTERNAL_PREVIEW
  EDEN_MANAGED
  LINKED_EXTERNAL
}

enum ProjectRuntimeTaskType {
  IMPLEMENTATION_PLAN
  ANALYSIS
  QA_REVIEW
}

enum ProjectRuntimeTaskStatus {
  PLANNING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                         String                   @id @default(cuid())
  username                   String                   @unique
  displayName                String
  passwordHash               String?
  role                       EdenRole                 @default(CONSUMER)
  status                     UserStatus               @default(ACTIVE)
  summary                    String?
  edenBalanceCredits         Int                      @default(0)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  ownedBusinesses            Business[]               @relation("BusinessOwner")
  businessMemberships        BusinessMember[]
  authProviderAccounts       AuthProviderAccount[]
  serviceUsages              ServiceUsage[]
  creditsTopUpPayments       CreditsTopUpPayment[]
  internalLeavesUsages       InternalLeavesUsage[]
  projectAgentRuns           ProjectAgentRun[]
  createdProjectBlueprints   ProjectBlueprint[]       @relation("ProjectBlueprintCreator")
  createdProjectRuntimes     ProjectRuntime[]         @relation("ProjectRuntimeCreator")
  createdProjectRuntimeTasks ProjectRuntimeTask[]     @relation("ProjectRuntimeTaskCreator")
  projectRuntimeAuditLogs    ProjectRuntimeAuditLog[] @relation("ProjectRuntimeAuditActor")
  receivedLeavesGrants       OwnerLeavesGrant[]       @relation("OwnerLeavesGrantRecipient")
  issuedLeavesGrants         OwnerLeavesGrant[]       @relation("OwnerLeavesGrantIssuer")
}

model AuthProviderAccount {
  id              String   @id @default(cuid())
  provider        String
  providerSubject String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
}

model Business {
  id                      String                @id @default(cuid())
  name                    String
  ownerUserId             String
  status                  BusinessStatus        @default(DRAFT)
  category                String
  tags                    String[]
  description             String
  summary                 String?
  tagline                 String?
  targetAudience          String?
  monetizationModel       String?
  visibility              BusinessVisibility    @default(PRIVATE_PREVIEW)
  teamLabel               String?
  creditBalanceCredits    Int                   @default(0)
  publishReadinessPercent Int                   @default(0)
  nextMilestone           String?
  featuredServiceId       String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  ownerUser               User                  @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members                 BusinessMember[]
  services                Service[]             @relation("BusinessServices")
  featuredService         Service?              @relation("FeaturedService", fields: [featuredServiceId], references: [id], onDelete: SetNull)
  pipelineRecords         PipelineRecord[]
  pipelineEvents          PipelineEvent[]
  payoutSettlements       PayoutSettlement[]
  internalLeavesUsages    InternalLeavesUsage[]
  projectBlueprints       ProjectBlueprint[]

  @@index([ownerUserId])
  @@index([status])
  @@index([category])
}

model ProjectBlueprint {
  id                      String                 @id @default(cuid())
  businessId              String
  creatorUserId           String
  title                   String
  description             String
  goal                    String
  status                  ProjectBlueprintStatus @default(DRAFT)
  hostingBalanceLeaves    Int                    @default(0)
  hostingBalanceUpdatedAt DateTime?
  publishedAt             DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  business                Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creatorUser             User                   @relation("ProjectBlueprintCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  agents                  ProjectAgent[]
  agentRuns               ProjectAgentRun[]
  runtimes                ProjectRuntime[]

  @@index([businessId, createdAt])
  @@index([creatorUserId, createdAt])
  @@index([status, createdAt])
}

model ProjectRuntime {
  id                String                     @id @default(cuid())
  projectId         String
  creatorUserId     String
  name              String
  purpose           String
  runtimeType       ProjectRuntimeType
  environment       ProjectRuntimeEnvironment  @default(DEVELOPMENT)
  target            ProjectRuntimeTarget       @default(EDEN_INTERNAL)
  accessPolicy      ProjectRuntimeAccessPolicy @default(BUSINESS_MEMBERS)
  visibility        ProjectRuntimeVisibility   @default(PRIVATE_PREVIEW)
  status            ProjectRuntimeStatus       @default(REGISTERED)
  runtimeLocator    String?
  statusDetail      String?
  lastHealthCheckAt DateTime?
  activatedAt       DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  project           ProjectBlueprint           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creatorUser       User                       @relation("ProjectRuntimeCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  domainLinks       ProjectRuntimeDomainLink[]
  tasks             ProjectRuntimeTask[]
  auditLogs         ProjectRuntimeAuditLog[]

  @@unique([projectId, environment, runtimeType])
  @@index([projectId, createdAt])
  @@index([runtimeType, environment, createdAt])
  @@index([status, createdAt])
}

model ProjectRuntimeDomainLink {
  id         String                       @id @default(cuid())
  runtimeId  String
  linkType   ProjectRuntimeDomainLinkType
  hostname   String
  pathPrefix String?
  isPrimary  Boolean                      @default(false)
  isActive   Boolean                      @default(false)
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  runtime    ProjectRuntime               @relation(fields: [runtimeId], references: [id], onDelete: Cascade)

  @@unique([runtimeId, hostname, pathPrefix])
  @@index([runtimeId, createdAt])
}

model ProjectRuntimeTask {
  id                 String                   @id @default(cuid())
  runtimeId          String
  creatorUserId      String
  title              String
  inputText          String
  taskType           ProjectRuntimeTaskType   @default(IMPLEMENTATION_PLAN)
  status             ProjectRuntimeTaskStatus @default(PLANNING)
  executionMode      String                   @default("synchronous_sandbox_v1")
  plannerSummary     String?
  plannerPayload     Json?
  workerSummary      String?
  workerPayload      Json?
  outputSummary      String?
  outputLines        String[]
  failureDetail      String?
  plannerCompletedAt DateTime?
  workerCompletedAt  DateTime?
  completedAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  runtime            ProjectRuntime           @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  creatorUser        User                     @relation("ProjectRuntimeTaskCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)

  @@index([runtimeId, createdAt])
  @@index([status, createdAt])
  @@index([taskType, createdAt])
}

model ProjectRuntimeAuditLog {
  id            String         @id @default(cuid())
  runtimeId     String
  actorUserId   String
  fieldName     String
  previousValue String?
  nextValue     String?
  detail        String
  createdAt     DateTime       @default(now())
  runtime       ProjectRuntime @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  actorUser     User           @relation("ProjectRuntimeAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([runtimeId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([fieldName, createdAt])
}

model ProjectAgent {
  id            String            @id @default(cuid())
  projectId     String
  name          String
  roleTitle     String
  instructions  String
  parentAgentId String?
  branchLabel   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  project       ProjectBlueprint  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentAgent   ProjectAgent?     @relation("ProjectAgentTree", fields: [parentAgentId], references: [id], onDelete: SetNull)
  childAgents   ProjectAgent[]    @relation("ProjectAgentTree")
  agentRuns     ProjectAgentRun[]

  @@index([projectId, createdAt])
  @@index([parentAgentId, createdAt])
}

model ProjectAgentRun {
  id            String           @id @default(cuid())
  projectId     String
  agentId       String
  userId        String?
  executionKey  String?          @unique
  prompt        String
  outputTitle   String
  outputSummary String
  outputLines   String[]
  costLeaves    Int
  createdAt     DateTime         @default(now())
  project       ProjectBlueprint @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent         ProjectAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([agentId, createdAt])
  @@index([userId, createdAt])
}

model BusinessMember {
  id         String             @id @default(cuid())
  businessId String
  userId     String
  role       BusinessMemberRole @default(MEMBER)
  title      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
}

model Service {
  id                   String           @id @default(cuid())
  businessId           String
  title                String
  category             String
  tags                 String[]
  description          String
  summary              String?
  status               PipelineStatus   @default(DRAFT)
  pricingModel         String?
  pricePerUse          Int?
  pricingType          String?
  pricingUnit          String?
  automationSummary    String?
  publishedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  business             Business         @relation("BusinessServices", fields: [businessId], references: [id], onDelete: Cascade)
  featuredInBusinesses Business[]       @relation("FeaturedService")
  pipelineRecords      PipelineRecord[]
  pipelineEvents       PipelineEvent[]
  serviceUsages        ServiceUsage[]

  @@index([businessId])
  @@index([status])
  @@index([category])
}

model ServiceUsage {
  id                     String   @id @default(cuid())
  serviceId              String
  userId                 String?
  executionKey           String?  @unique
  usageType              String
  creditsUsed            Int
  grossCredits           Int?
  platformFeeCredits     Int?
  builderEarningsCredits Int?
  createdAt              DateTime @default(now())
  service                Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user                   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceId, createdAt])
  @@index([userId, createdAt])
  @@index([usageType])
}

model CreditsTopUpPayment {
  id                      String                    @id @default(cuid())
  provider                String
  providerSessionId       String                    @unique
  providerPaymentIntentId String?
  userId                  String?
  creditsAmount           Int
  amountCents             Int
  currency                String
  status                  CreditsTopUpPaymentStatus @default(PENDING)
  failureReason           String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  settledAt               DateTime?
  user                    User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  paymentEventLogs        PaymentEventLog[]

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model PaymentEventLog {
  id                    String                @id @default(cuid())
  provider              String
  eventType             String
  providerEventId       String?
  creditsTopUpPaymentId String?
  providerSessionId     String?
  metadata              Json?
  status                PaymentEventLogStatus @default(INFO)
  createdAt             DateTime              @default(now())
  creditsTopUpPayment   CreditsTopUpPayment?  @relation(fields: [creditsTopUpPaymentId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([eventType, createdAt])
  @@index([providerEventId])
  @@index([providerSessionId, createdAt])
  @@index([creditsTopUpPaymentId, createdAt])
  @@index([status, createdAt])
}

model PayoutSettlement {
  id            String                 @id @default(cuid())
  businessId    String
  amountCredits Int
  status        PayoutSettlementStatus @default(SETTLED)
  reference     String?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  settledAt     DateTime?
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([status, createdAt])
}

model InternalLeavesUsage {
  id            String   @id @default(cuid())
  businessId    String
  userId        String?
  amountCredits Int
  usageType     String
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([usageType, createdAt])
}

model OwnerLeavesGrant {
  id              String   @id @default(cuid())
  userId          String
  grantedByUserId String
  amountCredits   Int
  note            String?
  createdAt       DateTime @default(now())
  user            User     @relation("OwnerLeavesGrantRecipient", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser   User     @relation("OwnerLeavesGrantIssuer", fields: [grantedByUserId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([grantedByUserId, createdAt])
}

model PipelineRecord {
  id              String          @id @default(cuid())
  businessId      String
  serviceId       String
  projectId       String?
  status          PipelineStatus  @default(DRAFT)
  buildStarted    Boolean         @default(false)
  lastActionLabel String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service         Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  events          PipelineEvent[]

  @@unique([businessId, serviceId])
  @@index([status])
}

model PipelineEvent {
  id               String          @id @default(cuid())
  pipelineRecordId String?
  businessId       String
  serviceId        String
  projectId        String?
  previousStatus   PipelineStatus
  newStatus        PipelineStatus
  actorLabel       String
  detail           String?
  occurredAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())
  pipelineRecord   PipelineRecord? @relation(fields: [pipelineRecordId], references: [id], onDelete: SetNull)
  business         Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service          Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([businessId, occurredAt])
  @@index([serviceId, occurredAt])
  @@index([newStatus])
}
