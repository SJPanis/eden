generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EdenRole {
  CONSUMER
  BUSINESS
  OWNER
}

enum UserStatus {
  ACTIVE
  REVIEW
  FROZEN
}

enum BusinessStatus {
  DRAFT
  TESTING
  PUBLISHED
}

enum BusinessVisibility {
  PRIVATE_PREVIEW
  INTERNAL_TESTING
  PUBLISHED
}

enum BusinessMemberRole {
  OWNER
  ADMIN
  EDITOR
  MEMBER
}

enum PipelineStatus {
  DRAFT
  TESTING
  READY
  PUBLISHED
}

enum CreditsTopUpPaymentStatus {
  PENDING
  SETTLED
  FAILED
  CANCELED
}

enum PaymentEventLogStatus {
  INFO
  SUCCESS
  SKIPPED
  FAILED
}

enum PayoutSettlementStatus {
  PENDING
  SETTLED
  CANCELED
}

enum ProjectBlueprintStatus {
  DRAFT
  TESTING
  PUBLISHED
  INACTIVE
}

enum ProjectRuntimeType {
  INTERNAL_SANDBOX
  INTERNAL_PREVIEW
  EDEN_MANAGED_INSTANCE
  EXTERNAL_LINKED_DOMAIN
}

enum ProjectRuntimeEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum ProjectRuntimeTarget {
  EDEN_INTERNAL
  EDEN_MANAGED
  EXTERNAL_DOMAIN
}

enum ProjectRuntimeAccessPolicy {
  OWNER_ONLY
  BUSINESS_MEMBERS
  PUBLIC
}

enum ProjectRuntimeVisibility {
  PRIVATE_INTERNAL
  PRIVATE_PREVIEW
  PUBLIC_LAUNCH
}

enum ProjectRuntimeStatus {
  REGISTERED
  CONFIGURING
  READY
  PAUSED
  ERROR
  ARCHIVED
}

enum ProjectRuntimeDomainLinkType {
  INTERNAL_PREVIEW
  EDEN_MANAGED
  LINKED_EXTERNAL
}

enum ProjectRuntimeLaunchIntentType {
  INTERNAL_PREVIEW
  EDEN_HOSTED
  LINKED_EXTERNAL
}

enum ProjectRuntimeLaunchMode {
  CONTROL_PLANE_ONLY
  EDEN_MANAGED_PROMOTION
  EXTERNAL_HANDOFF
}

enum ProjectRuntimeDeploymentEventType {
  LAUNCH_INTENT_UPDATED
  MANUAL_NOTE
  PREVIEW_CHECKPOINT
  HOSTED_CHECKPOINT
  EXTERNAL_LINK_CHECKPOINT
}

enum ProjectRuntimeDeploymentEventStatus {
  RECORDED
  PLANNED
  READY
  BLOCKED
  FAILED
}

enum EdenAiProvider {
  OPENAI
  ANTHROPIC
}

enum ProjectRuntimeProviderApprovalStatus {
  REVIEW_REQUIRED
  APPROVED
  DENIED
}

enum ProjectRuntimeConfigScope {
  OWNER_INTERNAL
  BUSINESS_RUNTIME
  PUBLIC_RUNTIME
}

enum ProjectRuntimeExecutionMode {
  CONTROL_PLANE_ONLY
  SANDBOX_TASK_RUNNER_V1
  FUTURE_RUNTIME_AGENT
  EXTERNAL_RUNTIME_HANDOFF
}

enum ProjectRuntimeProviderPolicyMode {
  EDEN_APPROVED_ONLY
  RUNTIME_ALLOWLIST
  OWNER_APPROVAL_REQUIRED
}

enum ProjectRuntimeSecretType {
  PROVIDER_API_KEY
  WEBHOOK_SECRET
  DATABASE_URL
  SERVICE_TOKEN
  ENVIRONMENT_GROUP
}

enum ProjectRuntimeSecretScope {
  RUNTIME_ONLY
  BUSINESS_SHARED
  OWNER_INTERNAL
}

enum ProjectRuntimeSecretVisibilityPolicy {
  STATUS_ONLY
  OWNER_METADATA_ONLY
  RUNTIME_BOUNDARY_ONLY
}

enum ProjectRuntimeSecretStatus {
  CONFIGURED
  MISSING
  PENDING
  RESERVED
}

enum ProjectRuntimeAgentActionType {
  PROVIDER_PREFLIGHT
  SANDBOX_TEST
  QA_VALIDATION
  IMPLEMENTATION_REVIEW
}

enum ProjectRuntimeAgentRunStatus {
  PREFLIGHT_BLOCKED
  PREPARED
  COMPLETED
  FAILED
  REVIEW_REQUIRED
}

enum ProjectRuntimeDispatchStatus {
  QUEUED
  READY
  BLOCKED
  DISPATCHED
  COMPLETED
  FAILED
  REVIEW_REQUIRED
}

enum ProjectRuntimeDispatchMode {
  CONTROL_PLANE_PREFLIGHT
  OWNER_REVIEW_GATE
  ASYNC_WORKER_HANDOFF
}

enum ProjectRuntimeExecutionRole {
  OWNER_SUPERVISOR
  RUNTIME_LEAD
  TOOL_WORKER
  BROWSER_WORKER
  QA_REVIEWER
}

enum ProjectRuntimeExecutionSessionType {
  SANDBOX_TASK
  TOOL_EXECUTION
  BROWSER_EXECUTION
  PROVIDER_EXECUTION
}

enum ProjectRuntimeExecutionSessionStatus {
  PREPARED
  BLOCKED
  REVIEW_REQUIRED
  CLOSED
}

enum ProjectRuntimeExecutionAdapterKind {
  PROVIDER
  TOOL
  BROWSER
}

enum ProjectRuntimeExecutionAdapterMode {
  PREFLIGHT_ONLY
  SCAFFOLD_ONLY
  LIVE_GUARDED
  FUTURE_LIVE
}

enum ProjectRuntimeTaskType {
  IMPLEMENTATION_PLAN
  ANALYSIS
  QA_REVIEW
}

enum ProjectRuntimeTaskStatus {
  PLANNING
  RUNNING
  COMPLETED
  FAILED
}

enum ProjectRuntimeTaskResultType {
  SANDBOX_PLAN
  PROVIDER_PREFLIGHT
  LIVE_PROVIDER_RESULT
  QA_RESULT
  EXECUTION_REVIEW
}

enum ProjectRuntimeTaskResultStatus {
  PASS
  FAIL
  REVIEW_NEEDED
  INFO
}

enum ProjectRuntimeTaskAuditEventType {
  TASK_CREATED
  PLANNER_COMPLETED
  WORKER_COMPLETED
  TASK_COMPLETED
  TASK_FAILED
  DISPATCH_PREPARED
  LIVE_EXECUTION_ATTEMPTED
  LIVE_EXECUTION_COMPLETED
  LIVE_EXECUTION_FAILED
}

model User {
  id                              String                           @id @default(cuid())
  username                        String                           @unique
  displayName                     String
  passwordHash                    String?
  role                            EdenRole                         @default(CONSUMER)
  status                          UserStatus                       @default(ACTIVE)
  summary                         String?
  edenBalanceCredits              Int                              @default(0)
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  ownedBusinesses                 Business[]                       @relation("BusinessOwner")
  businessMemberships             BusinessMember[]
  authProviderAccounts            AuthProviderAccount[]
  serviceUsages                   ServiceUsage[]
  creditsTopUpPayments            CreditsTopUpPayment[]
  internalLeavesUsages            InternalLeavesUsage[]
  projectAgentRuns                ProjectAgentRun[]
  createdProjectBlueprints        ProjectBlueprint[]               @relation("ProjectBlueprintCreator")
  createdProjectRuntimes          ProjectRuntime[]                 @relation("ProjectRuntimeCreator")
  createdProjectRuntimeTasks      ProjectRuntimeTask[]             @relation("ProjectRuntimeTaskCreator")
  projectRuntimeProviderApprovals ProjectRuntimeProviderApproval[] @relation("ProjectRuntimeProviderApprovalActor")
  projectRuntimeAgentRuns         ProjectRuntimeAgentRun[]         @relation("ProjectRuntimeAgentRunActor")
  projectRuntimeDispatchRecords   ProjectRuntimeDispatchRecord[]   @relation("ProjectRuntimeDispatchActor")
  projectRuntimeExecutionSessions ProjectRuntimeExecutionSession[] @relation("ProjectRuntimeExecutionSessionActor")
  projectRuntimeAuditLogs         ProjectRuntimeAuditLog[]         @relation("ProjectRuntimeAuditActor")
  projectRuntimeTaskAuditLogs     ProjectRuntimeTaskAuditLog[]     @relation("ProjectRuntimeTaskAuditActor")
  projectRuntimeDeploymentRecords ProjectRuntimeDeploymentRecord[] @relation("ProjectRuntimeDeploymentActor")
  receivedLeavesGrants            OwnerLeavesGrant[]               @relation("OwnerLeavesGrantRecipient")
  issuedLeavesGrants              OwnerLeavesGrant[]               @relation("OwnerLeavesGrantIssuer")
  wallet                          EdenWallet?
  edenTransactions                EdenTransaction[]                @relation("EdenTransactionActor")
  contributionRecords             ContributionRecord[]             @relation("ContributorRecords")
  reviewedContributions           ContributionRecord[]             @relation("ContributionReviewer")
  contributionAllocations         ContributionAllocation[]         @relation("ContributionAllocationRecipient")
  accessCodeId                    String?
  accessCode                      EarlyAccessCode?                 @relation("UserAccessCode", fields: [accessCodeId], references: [id])
}

model AuthProviderAccount {
  id              String   @id @default(cuid())
  provider        String
  providerSubject String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
}

model Business {
  id                      String                @id @default(cuid())
  name                    String
  ownerUserId             String
  status                  BusinessStatus        @default(DRAFT)
  category                String
  tags                    String[]
  description             String
  summary                 String?
  tagline                 String?
  targetAudience          String?
  monetizationModel       String?
  visibility              BusinessVisibility    @default(PRIVATE_PREVIEW)
  teamLabel               String?
  creditBalanceCredits    Int                   @default(0)
  publishReadinessPercent Int                   @default(0)
  nextMilestone           String?
  featuredServiceId       String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  ownerUser               User                  @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members                 BusinessMember[]
  services                Service[]             @relation("BusinessServices")
  featuredService         Service?              @relation("FeaturedService", fields: [featuredServiceId], references: [id], onDelete: SetNull)
  pipelineRecords         PipelineRecord[]
  pipelineEvents          PipelineEvent[]
  payoutSettlements       PayoutSettlement[]
  internalLeavesUsages    InternalLeavesUsage[]
  projectBlueprints       ProjectBlueprint[]
  edenTransactions        EdenTransaction[]
  contributionRecords     ContributionRecord[]

  @@index([ownerUserId])
  @@index([status])
  @@index([category])
}

model ProjectBlueprint {
  id                      String                 @id @default(cuid())
  businessId              String
  creatorUserId           String
  title                   String
  description             String
  goal                    String
  status                  ProjectBlueprintStatus @default(DRAFT)
  hostingBalanceLeaves    Int                    @default(0)
  hostingBalanceUpdatedAt DateTime?
  publishedAt             DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  business                Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creatorUser             User                   @relation("ProjectBlueprintCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  agents                  ProjectAgent[]
  agentRuns               ProjectAgentRun[]
  runtimes                ProjectRuntime[]

  @@index([businessId, createdAt])
  @@index([creatorUserId, createdAt])
  @@index([status, createdAt])
}

model ProjectRuntime {
  id                String                           @id @default(cuid())
  projectId         String
  creatorUserId     String
  name              String
  purpose           String
  runtimeType       ProjectRuntimeType
  environment       ProjectRuntimeEnvironment        @default(DEVELOPMENT)
  target            ProjectRuntimeTarget             @default(EDEN_INTERNAL)
  accessPolicy      ProjectRuntimeAccessPolicy       @default(BUSINESS_MEMBERS)
  visibility        ProjectRuntimeVisibility         @default(PRIVATE_PREVIEW)
  status            ProjectRuntimeStatus             @default(REGISTERED)
  runtimeLocator    String?
  statusDetail      String?
  lastHealthCheckAt DateTime?
  activatedAt       DateTime?
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt
  project           ProjectBlueprint                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creatorUser       User                             @relation("ProjectRuntimeCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  domainLinks       ProjectRuntimeDomainLink[]
  launchIntent      ProjectRuntimeLaunchIntent?
  configPolicy      ProjectRuntimeConfigPolicy?
  secretBoundaries  ProjectRuntimeSecretBoundary[]
  tasks             ProjectRuntimeTask[]
  providerApprovals ProjectRuntimeProviderApproval[]
  agentRuns         ProjectRuntimeAgentRun[]
  executionSessions ProjectRuntimeExecutionSession[]
  dispatchRecords   ProjectRuntimeDispatchRecord[]
  auditLogs         ProjectRuntimeAuditLog[]
  taskAuditLogs     ProjectRuntimeTaskAuditLog[]
  deploymentRecords ProjectRuntimeDeploymentRecord[]
  edenTransactions  EdenTransaction[]
  contributions     ContributionRecord[]

  @@unique([projectId, environment, runtimeType])
  @@index([projectId, createdAt])
  @@index([runtimeType, environment, createdAt])
  @@index([status, createdAt])
}

model ProjectRuntimeDomainLink {
  id         String                       @id @default(cuid())
  runtimeId  String
  linkType   ProjectRuntimeDomainLinkType
  hostname   String
  pathPrefix String?
  isPrimary  Boolean                      @default(false)
  isActive   Boolean                      @default(false)
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  runtime    ProjectRuntime               @relation(fields: [runtimeId], references: [id], onDelete: Cascade)

  @@unique([runtimeId, hostname, pathPrefix])
  @@index([runtimeId, createdAt])
}

model ProjectRuntimeLaunchIntent {
  id               String                         @id @default(cuid())
  runtimeId        String                         @unique
  intentType       ProjectRuntimeLaunchIntentType @default(INTERNAL_PREVIEW)
  intendedTarget   ProjectRuntimeTarget           @default(EDEN_INTERNAL)
  launchMode       ProjectRuntimeLaunchMode       @default(CONTROL_PLANE_ONLY)
  destinationLabel String?
  notes            String?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  runtime          ProjectRuntime                 @relation(fields: [runtimeId], references: [id], onDelete: Cascade)

  @@index([intentType, createdAt])
  @@index([intendedTarget, createdAt])
}

model ProjectRuntimeConfigPolicy {
  id                    String                           @id @default(cuid())
  runtimeId             String                           @unique
  configScope           ProjectRuntimeConfigScope        @default(BUSINESS_RUNTIME)
  executionMode         ProjectRuntimeExecutionMode      @default(CONTROL_PLANE_ONLY)
  providerPolicyMode    ProjectRuntimeProviderPolicyMode @default(EDEN_APPROVED_ONLY)
  allowedProviders      EdenAiProvider[]
  defaultProvider       EdenAiProvider?
  maxTaskBudgetLeaves   Int?
  monthlyBudgetLeaves   Int?
  modelPolicySummary    String?
  secretPolicyReference String?
  notes                 String?
  ownerOnlyEnforced     Boolean                          @default(false)
  internalOnlyEnforced  Boolean                          @default(false)
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  runtime               ProjectRuntime                   @relation(fields: [runtimeId], references: [id], onDelete: Cascade)

  @@index([configScope, createdAt])
  @@index([executionMode, createdAt])
  @@index([providerPolicyMode, createdAt])
}

model ProjectRuntimeSecretBoundary {
  id                String                               @id @default(cuid())
  runtimeId         String
  label             String
  description       String?
  secretType        ProjectRuntimeSecretType
  secretScope       ProjectRuntimeSecretScope
  visibilityPolicy  ProjectRuntimeSecretVisibilityPolicy
  status            ProjectRuntimeSecretStatus           @default(MISSING)
  statusDetail      String?
  isRequired        Boolean                              @default(true)
  providerKey       EdenAiProvider?
  boundaryReference String?
  lastCheckedAt     DateTime?
  createdAt         DateTime                             @default(now())
  updatedAt         DateTime                             @updatedAt
  runtime           ProjectRuntime                       @relation(fields: [runtimeId], references: [id], onDelete: Cascade)

  @@unique([runtimeId, label])
  @@index([runtimeId, createdAt])
  @@index([secretType, createdAt])
  @@index([status, createdAt])
}

model ProjectRuntimeProviderApproval {
  id              String                               @id @default(cuid())
  runtimeId       String
  actorUserId     String
  providerKey     EdenAiProvider
  approvalStatus  ProjectRuntimeProviderApprovalStatus @default(REVIEW_REQUIRED)
  modelScope      String[]
  capabilityScope String[]
  notes           String?
  reviewedAt      DateTime?
  createdAt       DateTime                             @default(now())
  updatedAt       DateTime                             @updatedAt
  runtime         ProjectRuntime                       @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  actorUser       User                                 @relation("ProjectRuntimeProviderApprovalActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@unique([runtimeId, providerKey])
  @@index([runtimeId, createdAt])
  @@index([providerKey, createdAt])
  @@index([approvalStatus, createdAt])
}

model ProjectRuntimeTask {
  id                  String                          @id @default(cuid())
  runtimeId           String
  creatorUserId       String
  title               String
  inputText           String
  providerKey         EdenAiProvider?
  modelLabel          String?
  requestedActionType ProjectRuntimeAgentActionType?
  taskType            ProjectRuntimeTaskType          @default(IMPLEMENTATION_PLAN)
  status              ProjectRuntimeTaskStatus        @default(PLANNING)
  executionMode       String                          @default("synchronous_sandbox_v1")
  plannerSummary      String?
  plannerPayload      Json?
  workerSummary       String?
  workerPayload       Json?
  outputSummary       String?
  outputLines         String[]
  resultType          ProjectRuntimeTaskResultType?
  resultStatus        ProjectRuntimeTaskResultStatus?
  resultSummary       String?
  resultPayload       Json?
  failureDetail       String?
  plannerCompletedAt  DateTime?
  workerCompletedAt   DateTime?
  completedAt         DateTime?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  runtime             ProjectRuntime                  @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  creatorUser         User                            @relation("ProjectRuntimeTaskCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  agentRuns           ProjectRuntimeAgentRun[]
  dispatchRecords     ProjectRuntimeDispatchRecord[]
  taskAuditLogs       ProjectRuntimeTaskAuditLog[]

  @@index([runtimeId, createdAt])
  @@index([status, createdAt])
  @@index([taskType, createdAt])
}

model ProjectRuntimeAgentRun {
  id                   String                        @id @default(cuid())
  runtimeId            String
  taskId               String?
  actorUserId          String
  providerKey          EdenAiProvider?
  modelLabel           String?
  executionTargetLabel String?
  requestedActionType  ProjectRuntimeAgentActionType
  runStatus            ProjectRuntimeAgentRunStatus  @default(PREPARED)
  summary              String
  detail               String?
  resultPayload        Json?
  errorDetail          String?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  completedAt          DateTime?
  runtime              ProjectRuntime                @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  task                 ProjectRuntimeTask?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actorUser            User                          @relation("ProjectRuntimeAgentRunActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([runtimeId, createdAt])
  @@index([taskId, createdAt])
  @@index([runStatus, createdAt])
  @@index([providerKey, createdAt])
}

model ProjectRuntimeExecutionSession {
  id                  String                               @id @default(cuid())
  runtimeId           String
  actorUserId         String
  sessionLabel        String
  sessionType         ProjectRuntimeExecutionSessionType
  executionRole       ProjectRuntimeExecutionRole
  adapterKind         ProjectRuntimeExecutionAdapterKind
  adapterMode         ProjectRuntimeExecutionAdapterMode   @default(PREFLIGHT_ONLY)
  providerKey         EdenAiProvider?
  status              ProjectRuntimeExecutionSessionStatus @default(PREPARED)
  allowedCapabilities String[]
  ownerOnly           Boolean                              @default(false)
  internalOnly        Boolean                              @default(false)
  notes               String?
  createdAt           DateTime                             @default(now())
  updatedAt           DateTime                             @updatedAt
  runtime             ProjectRuntime                       @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  actorUser           User                                 @relation("ProjectRuntimeExecutionSessionActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  dispatchRecords     ProjectRuntimeDispatchRecord[]

  @@index([runtimeId, createdAt])
  @@index([status, createdAt])
  @@index([executionRole, createdAt])
}

model ProjectRuntimeDispatchRecord {
  id             String                             @id @default(cuid())
  runtimeId      String
  taskId         String?
  actorUserId    String
  sessionId      String?
  providerKey    EdenAiProvider?
  modelLabel     String?
  dispatchStatus ProjectRuntimeDispatchStatus       @default(QUEUED)
  dispatchMode   ProjectRuntimeDispatchMode         @default(CONTROL_PLANE_PREFLIGHT)
  executionRole  ProjectRuntimeExecutionRole
  adapterKind    ProjectRuntimeExecutionAdapterKind
  adapterKey     String
  adapterMode    ProjectRuntimeExecutionAdapterMode @default(PREFLIGHT_ONLY)
  summary        String
  detail         String?
  dispatchReason String?
  blockingReason String?
  reviewRequired Boolean                            @default(false)
  resultPayload  Json?
  preparedAt     DateTime                           @default(now())
  dispatchedAt   DateTime?
  completedAt    DateTime?
  createdAt      DateTime                           @default(now())
  updatedAt      DateTime                           @updatedAt
  runtime        ProjectRuntime                     @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  task           ProjectRuntimeTask?                @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actorUser      User                               @relation("ProjectRuntimeDispatchActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  session        ProjectRuntimeExecutionSession?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([runtimeId, createdAt])
  @@index([taskId, createdAt])
  @@index([dispatchStatus, createdAt])
  @@index([adapterKind, createdAt])
}

model ProjectRuntimeAuditLog {
  id            String         @id @default(cuid())
  runtimeId     String
  actorUserId   String
  fieldName     String
  previousValue String?
  nextValue     String?
  detail        String
  createdAt     DateTime       @default(now())
  runtime       ProjectRuntime @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  actorUser     User           @relation("ProjectRuntimeAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([runtimeId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([fieldName, createdAt])
}

model ProjectRuntimeTaskAuditLog {
  id          String                             @id @default(cuid())
  runtimeId   String
  taskId      String
  actorUserId String
  eventType   ProjectRuntimeTaskAuditEventType
  detail      String
  metadata    Json?
  createdAt   DateTime                           @default(now())
  runtime     ProjectRuntime                     @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  task        ProjectRuntimeTask                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorUser   User                               @relation("ProjectRuntimeTaskAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([runtimeId, createdAt])
  @@index([taskId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([eventType, createdAt])
}

model ProjectRuntimeDeploymentRecord {
  id          String                              @id @default(cuid())
  runtimeId   String
  actorUserId String
  eventType   ProjectRuntimeDeploymentEventType
  eventStatus ProjectRuntimeDeploymentEventStatus @default(RECORDED)
  summary     String
  detail      String?
  createdAt   DateTime                            @default(now())
  runtime     ProjectRuntime                      @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
  actorUser   User                                @relation("ProjectRuntimeDeploymentActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([runtimeId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([eventType, createdAt])
  @@index([eventStatus, createdAt])
}

model ProjectAgent {
  id            String            @id @default(cuid())
  projectId     String
  name          String
  roleTitle     String
  instructions  String
  parentAgentId String?
  branchLabel   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  project       ProjectBlueprint  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentAgent   ProjectAgent?     @relation("ProjectAgentTree", fields: [parentAgentId], references: [id], onDelete: SetNull)
  childAgents   ProjectAgent[]    @relation("ProjectAgentTree")
  agentRuns     ProjectAgentRun[]

  @@index([projectId, createdAt])
  @@index([parentAgentId, createdAt])
}

model ProjectAgentRun {
  id            String           @id @default(cuid())
  projectId     String
  agentId       String
  userId        String?
  executionKey  String?          @unique
  prompt        String
  outputTitle   String
  outputSummary String
  outputLines   String[]
  costLeaves    Int
  createdAt     DateTime         @default(now())
  project       ProjectBlueprint @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent         ProjectAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([agentId, createdAt])
  @@index([userId, createdAt])
}

model BusinessMember {
  id         String             @id @default(cuid())
  businessId String
  userId     String
  role       BusinessMemberRole @default(MEMBER)
  title      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
}

model Service {
  id                   String           @id @default(cuid())
  businessId           String
  title                String
  category             String
  tags                 String[]
  description          String
  summary              String?
  status               PipelineStatus   @default(DRAFT)
  pricingModel         String?
  pricePerUse          Int?
  pricingType          String?
  pricingUnit          String?
  automationSummary    String?
  publishedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  business             Business         @relation("BusinessServices", fields: [businessId], references: [id], onDelete: Cascade)
  featuredInBusinesses Business[]       @relation("FeaturedService")
  pipelineRecords      PipelineRecord[]
  pipelineEvents       PipelineEvent[]
  serviceUsages        ServiceUsage[]

  @@index([businessId])
  @@index([status])
  @@index([category])
}

model ServiceUsage {
  id                     String   @id @default(cuid())
  serviceId              String
  userId                 String?
  executionKey           String?  @unique
  usageType              String
  creditsUsed            Int
  grossCredits           Int?
  platformFeeCredits     Int?
  builderEarningsCredits Int?
  createdAt              DateTime @default(now())
  service                Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user                   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceId, createdAt])
  @@index([userId, createdAt])
  @@index([usageType])
}

model CreditsTopUpPayment {
  id                      String                    @id @default(cuid())
  provider                String
  providerSessionId       String                    @unique
  providerPaymentIntentId String?
  userId                  String?
  creditsAmount           Int
  amountCents             Int
  currency                String
  status                  CreditsTopUpPaymentStatus @default(PENDING)
  failureReason           String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  settledAt               DateTime?
  user                    User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  paymentEventLogs        PaymentEventLog[]

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model PaymentEventLog {
  id                    String                @id @default(cuid())
  provider              String
  eventType             String
  providerEventId       String?
  creditsTopUpPaymentId String?
  providerSessionId     String?
  metadata              Json?
  status                PaymentEventLogStatus @default(INFO)
  createdAt             DateTime              @default(now())
  creditsTopUpPayment   CreditsTopUpPayment?  @relation(fields: [creditsTopUpPaymentId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([eventType, createdAt])
  @@index([providerEventId])
  @@index([providerSessionId, createdAt])
  @@index([creditsTopUpPaymentId, createdAt])
  @@index([status, createdAt])
}

model PayoutSettlement {
  id            String                 @id @default(cuid())
  businessId    String
  amountCredits Int
  status        PayoutSettlementStatus @default(SETTLED)
  reference     String?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  settledAt     DateTime?
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([status, createdAt])
}

model InternalLeavesUsage {
  id            String   @id @default(cuid())
  businessId    String
  userId        String?
  amountCredits Int
  usageType     String
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([usageType, createdAt])
}

model OwnerLeavesGrant {
  id              String   @id @default(cuid())
  userId          String
  grantedByUserId String
  amountCredits   Int
  note            String?
  createdAt       DateTime @default(now())
  user            User     @relation("OwnerLeavesGrantRecipient", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser   User     @relation("OwnerLeavesGrantIssuer", fields: [grantedByUserId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([grantedByUserId, createdAt])
}

model PipelineRecord {
  id              String          @id @default(cuid())
  businessId      String
  serviceId       String
  projectId       String?
  status          PipelineStatus  @default(DRAFT)
  buildStarted    Boolean         @default(false)
  lastActionLabel String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service         Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  events          PipelineEvent[]

  @@unique([businessId, serviceId])
  @@index([status])
}

model PipelineEvent {
  id               String          @id @default(cuid())
  pipelineRecordId String?
  businessId       String
  serviceId        String
  projectId        String?
  previousStatus   PipelineStatus
  newStatus        PipelineStatus
  actorLabel       String
  detail           String?
  occurredAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())
  pipelineRecord   PipelineRecord? @relation(fields: [pipelineRecordId], references: [id], onDelete: SetNull)
  business         Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service          Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([businessId, occurredAt])
  @@index([serviceId, occurredAt])
  @@index([newStatus])
}

// ─── Eden Economy MVP ─────────────────────────────────────────────────────────

enum EdenTransactionType {
  LEAFS_TOPUP
  LEAFS_DEDUCTION
  LEAFS_GRANT
  SERVICE_PURCHASE
  BUILDER_PAYOUT
  CONTRIBUTION_BONUS
  PLATFORM_FEE
  PROVIDER_RESERVE
  CONTRIBUTION_POOL
  MANUAL_ADJUSTMENT
}

enum EdenTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum EdenContributionType {
  CODE_IMPROVEMENT
  DESIGN_IMPROVEMENT
  BUG_FIX
  DOCS_IMPROVEMENT
  BUSINESS_TEMPLATE
  RUNTIME_IMPROVEMENT
  FEEDBACK_ADOPTED
  OTHER
}

enum EdenContributionStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum EdenContributionPeriodStatus {
  OPEN
  CLOSED
  DISTRIBUTED
}

model EdenWallet {
  id                   String            @id @default(cuid())
  userId               String            @unique
  leafsBalance         Int               @default(0)
  lockedLeafs          Int               @default(0)
  totalPurchasedLeafs  Int               @default(0)
  totalGrantedLeafs    Int               @default(0)
  totalSpentLeafs      Int               @default(0)
  contributionScore    Int               @default(0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         EdenTransaction[]

  @@index([userId])
}

model EdenTransaction {
  id                      String                @id @default(cuid())
  walletId                String
  actorUserId             String
  businessId              String?
  runtimeId               String?
  transactionType         EdenTransactionType
  status                  EdenTransactionStatus @default(PENDING)
  // Cash amounts are stored in cents to avoid floating point
  cashAmountCents         Int?
  leafsAmount             Int?
  // Fee split buckets (in Leaf's units)
  builderEarningsLeafs    Int?
  platformFeeLeafs        Int?
  providerReserveLeafs    Int?
  contributionPoolLeafs   Int?
  description             String
  metadata                Json?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  wallet                  EdenWallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  actor                   User                  @relation("EdenTransactionActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  business                Business?             @relation(fields: [businessId], references: [id], onDelete: SetNull)
  runtime                 ProjectRuntime?       @relation(fields: [runtimeId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([transactionType, createdAt])
  @@index([status, createdAt])
  @@index([businessId, createdAt])
}

model ContributionRecord {
  id                      String                 @id @default(cuid())
  contributorUserId       String
  reviewedByUserId        String?
  runtimeId               String?
  businessId              String?
  contributionType        EdenContributionType
  title                   String
  summary                 String
  artifactRef             String?
  evidenceRef             String?
  status                  EdenContributionStatus @default(SUBMITTED)
  approvedAt              DateTime?
  contributionScoreAwarded Int?
  leavesBonusAwarded      Int?
  notes                   String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  contributor             User                   @relation("ContributorRecords", fields: [contributorUserId], references: [id], onDelete: Cascade)
  reviewer                User?                  @relation("ContributionReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  runtime                 ProjectRuntime?        @relation(fields: [runtimeId], references: [id], onDelete: SetNull)
  business                Business?              @relation(fields: [businessId], references: [id], onDelete: SetNull)
  allocations             ContributionAllocation[]

  @@index([contributorUserId, createdAt])
  @@index([status, createdAt])
  @@index([contributionType, createdAt])
}

model ContributionPeriod {
  id              String                       @id @default(cuid())
  label           String
  startDate       DateTime
  endDate         DateTime
  poolLeafs       Int                          @default(0)
  poolCashCents   Int                          @default(0)
  status          EdenContributionPeriodStatus @default(OPEN)
  notes           String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  allocations     ContributionAllocation[]

  @@index([status, startDate])
}

model ContributionAllocation {
  id                  String              @id @default(cuid())
  periodId            String
  contributionId      String
  contributorUserId   String
  scoreWeight         Float               @default(0)
  percentOfPool       Float               @default(0)
  leafsGranted        Int                 @default(0)
  cashAllocatedCents  Int                 @default(0)
  status              EdenTransactionStatus @default(PENDING)
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  period              ContributionPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)
  contribution        ContributionRecord  @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  contributor         User                @relation("ContributionAllocationRecipient", fields: [contributorUserId], references: [id], onDelete: Cascade)

  @@index([periodId, contributorUserId])
  @@index([contributorUserId, createdAt])
  @@index([status])
}

// ── Early Access ──────────────────────────────────────────────────────────────

model EarlyAccessCode {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String?
  maxUses   Int      @default(50)
  useCount  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  usedBy    User[]   @relation("UserAccessCode")
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  note      String?
  createdAt DateTime @default(now())
}
